{
  "name": "@ai-skills-share/api",
  "version": "0.1.0-alpha.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "node ../../scripts/run-node-tests.mjs --import tsx --extensions .test.ts"
  },
  "dependencies": {
    "@ai-skills-share/auth": "0.1.0-alpha.0",
    "@ai-skills-share/core": "0.1.0-alpha.0",
    "@ai-skills-share/skill-package": "0.1.0-alpha.0",
    "@aws-sdk/client-s3": "^3.1061.0",
    "drizzle-orm": "^0.45.0",
    "fastify": "^5.6.2",
    "nodemailer": "^8.0.10",
    "pg": "^8.16.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
