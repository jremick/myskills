{
  "name": "@myskills-app/api",
  "version": "0.1.0-beta.1",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "node ../../scripts/run-node-tests.mjs --import tsx --extensions .test.ts",
    "test:postgres": "node -e \"if (!process.env.TEST_DATABASE_URL) { console.error('TEST_DATABASE_URL is required.'); process.exit(1); }\" && node ../../scripts/run-node-tests.mjs --import tsx --extensions .pgtest.ts --test-concurrency=1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1061.0",
    "@myskills-app/auth": "0.1.0-beta.1",
    "@myskills-app/core": "0.1.0-beta.1",
    "@myskills-app/skill-package": "0.1.0-beta.1",
    "drizzle-orm": "^0.45.0",
    "fastify": "^5.6.2",
    "nodemailer": "^9.0.1",
    "pg": "^8.16.3",
    "resend": "^6.12.4",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.15.6",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  }
}
