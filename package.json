{
  "name": "myskills-app",
  "version": "0.1.0-beta.0",
  "license": "Apache-2.0",
  "private": true,
  "description": "Open-source skill registry, sharing, installation, API, MCP, and CLI platform for AI agent skills.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "audit:prod": "npm audit --omit=dev",
    "check": "npm run check:structure && npm run check:privacy && npm run scan:secrets && npm run audit:prod && npm run build && npm run check:alpha-release && npm run test",
    "check:alpha-release": "npm run build -w @myskills-app/skill-package && node scripts/check-alpha-release.mjs",
    "check:prod-env": "node scripts/check-production-env.mjs",
    "check:privacy": "node scripts/check-privacy.mjs",
    "check:structure": "node scripts/check-structure.mjs",
    "db:migrate": "npm run db:migrate -w @myskills-app/api",
    "db:seed": "npm run db:seed -w @myskills-app/api",
    "dev:api": "npm run dev -w @myskills-app/api",
    "dev:mcp": "npm run dev -w @myskills-app/mcp",
    "dev:mcp:http": "npm run dev:http -w @myskills-app/mcp",
    "dev:web": "npm run dev -w @myskills-app/web",
    "docker:down": "docker compose down",
    "docker:up": "docker compose up -d postgres minio minio-init",
    "release:artifacts": "node scripts/create-release-artifacts.mjs",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "start:mcp:http": "npm run start:http -w @myskills-app/mcp",
    "test": "npm test --workspaces --if-present",
    "test:postgres": "npm run build && npm run test:postgres -w @myskills-app/api"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.12.1"
}
