# Copy to .env.production and replace every placeholder before deployment.
# This file is intentionally not suitable for local development.

NODE_ENV=production

# Public origins. APP_BASE_URL is the browser/web origin used in auth action links.
APP_BASE_URL=https://skills.example.com
VITE_API_BASE_URL=https://api.skills.example.com
ALLOWED_WEB_ORIGINS=https://skills.example.com

# Single-host Compose ports. Put a TLS reverse proxy in front of these ports.
WEB_PORT=3000
API_PORT=3001
MCP_HTTP_PORT=3002

# Database.
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
DATABASE_URL=postgres://ai_skills_share:replace-with-a-long-random-postgres-password@postgres:5432/ai_skills_share

# Application auth. Use at least 32 random bytes; 64+ is better.
AUTH_SECRET=replace-with-at-least-32-random-bytes
TOTP_ISSUER=AI Skills Share

# First owner bootstrap. Run the seed service once, then rotate/remove the password.
SEED_OWNER_EMAIL=owner@example.com
SEED_OWNER_PASSWORD=replace-with-a-long-random-bootstrap-password

# Auth action email delivery. Production does not allow console delivery.
AUTH_NOTIFICATION_MODE=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_FROM=AI Skills Share <noreply@example.com>
SMTP_USER=
SMTP_PASSWORD=

# Object storage. The production Compose example uses internal MinIO.
ARTIFACT_STORAGE_MODE=s3
MINIO_ROOT_USER=replace-with-a-random-minio-access-key
MINIO_ROOT_PASSWORD=replace-with-a-random-minio-secret-key
S3_REGION=local
S3_BUCKET=ai-skills-share

# Optional Streamable HTTP MCP service. Required if using the mcp profile with
# AI_SKILLS_MCP_HOST=0.0.0.0.
AI_SKILLS_API_URL=http://api:3001
AI_SKILLS_MCP_HOST=0.0.0.0
AI_SKILLS_MCP_PORT=3002
AI_SKILLS_MCP_ALLOWED_HOSTS=mcp.skills.example.com
AI_SKILLS_MCP_ALLOWED_ORIGINS=https://skills.example.com
AI_SKILLS_MCP_PATH=/mcp
