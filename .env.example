# Local development defaults only. Do not use these values in production.

NODE_ENV=development
PORT=3001

DATABASE_URL=postgres://ai_skills_share:ai_skills_share_dev@localhost:5432/ai_skills_share
AUTH_SECRET=dev-only-myskills-app-auth-secret-change-before-production
TOTP_ISSUER=MySkills

ARTIFACT_STORAGE_MODE=s3
S3_ENDPOINT=http://localhost:9000
S3_REGION=local
S3_BUCKET=myskills-app-dev
S3_ACCESS_KEY_ID=myskills-app
S3_SECRET_ACCESS_KEY=myskills-app-dev
S3_FORCE_PATH_STYLE=true

APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001
ALLOWED_WEB_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
VITE_API_BASE_URL=http://localhost:3001
MYSKILLS_API_URL=http://localhost:3001

# Auth action notifications: console is for local development only. Production can use Resend or SMTP and requires HTTPS APP_BASE_URL.
AUTH_NOTIFICATION_MODE=console
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM="MySkills <noreply@example.com>"
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_REQUIRE_TLS=true
# SMTP_TLS_REJECT_UNAUTHORIZED=true
# SMTP_FROM="MySkills <noreply@example.com>"
# SMTP_USER=
# SMTP_PASSWORD=

# Create this with: myskills token create --name "MCP" --scope skills:read
MYSKILLS_TOKEN=

SEED_OWNER_EMAIL=owner@example.com
SEED_OWNER_PASSWORD=change-me-now-please
