# Local development defaults only. Do not use these values in production.

NODE_ENV=development
PORT=3001

DATABASE_URL=postgres://ai_skills_share:ai_skills_share_dev@localhost:5432/ai_skills_share
AUTH_SECRET=dev-only-ai-skills-share-auth-secret-change-before-production
TOTP_ISSUER=AI Skills Share

ARTIFACT_STORAGE_MODE=s3
S3_ENDPOINT=http://localhost:9000
S3_REGION=local
S3_BUCKET=ai-skills-share-dev
S3_ACCESS_KEY_ID=ai-skills-share
S3_SECRET_ACCESS_KEY=ai-skills-share-dev
S3_FORCE_PATH_STYLE=true

APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001
ALLOWED_WEB_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
VITE_API_BASE_URL=http://localhost:3001
AI_SKILLS_API_URL=http://localhost:3001

# Auth action notifications: console is for local development only. Production defaults to smtp and requires HTTPS APP_BASE_URL.
AUTH_NOTIFICATION_MODE=console
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_REQUIRE_TLS=true
# SMTP_TLS_REJECT_UNAUTHORIZED=true
# SMTP_FROM="AI Skills Share <noreply@example.com>"
# SMTP_USER=
# SMTP_PASSWORD=

# Create this with: ai-skills token create --name "MCP" --scope skills:read
AI_SKILLS_TOKEN=

SEED_OWNER_EMAIL=owner@example.com
SEED_OWNER_PASSWORD=change-me-now-please
